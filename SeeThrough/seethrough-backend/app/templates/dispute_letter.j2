<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2c3e50;
            font-size: 24px;
        }
        .section {
            margin-bottom: 20px;
        }
        .section-title {
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .evidence-list {
            background-color: #f8f9fa;
            padding: 15px;
            border-left: 4px solid #3498db;
            margin: 10px 0;
        }
        .evidence-item {
            font-family: monospace;
            font-size: 12px;
            margin: 5px 0;
        }
        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Dispute Letter - See-Through Checkout</h1>
        <p>Generated: {{ generated_date }}</p>
    </div>

    <div class="section">
        <div class="section-title">From:</div>
        <p>{{ user_email }}</p>
    </div>

    <div class="section">
        <div class="section-title">Regarding:</div>
        <p>
            <strong>Merchant:</strong> {{ merchant_domain }}<br>
            <strong>Transaction Amount:</strong> ${{ "%.2f"|format(amount) }}<br>
            <strong>Transaction Date:</strong> {{ transaction_date }}
        </p>
    </div>

    <div class="section">
        <div class="section-title">Dispute Reason:</div>
        <p>{{ reason }}</p>
    </div>

    <div class="section">
        <div class="section-title">Evidence:</div>
        <p>The following evidence has been collected to support this dispute:</p>
        <div class="evidence-list">
            {% if evidence_hashes %}
                {% for hash in evidence_hashes %}
                <div class="evidence-item">SHA256: {{ hash }}</div>
                {% endfor %}
            {% else %}
                <div class="evidence-item">No evidence files attached</div>
            {% endif %}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Declaration:</div>
        <p>
            I hereby certify that the information provided in this dispute is accurate and complete
            to the best of my knowledge. I request that this transaction be investigated and appropriate
            action be taken in accordance with applicable consumer protection laws and payment network rules.
        </p>
    </div>

    <div class="footer">
        <p>
            This dispute letter was generated by See-Through Checkout, a service designed to protect
            consumers from dark patterns and hidden fees in online checkout processes.
        </p>
        <p>
            <strong>Note:</strong> This is an automated document. Evidence hashes are cryptographic
            fingerprints (SHA256) that verify the authenticity of captured evidence.
        </p>
    </div>
</body>
</html>

